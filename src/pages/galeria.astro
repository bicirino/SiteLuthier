---
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'
---
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Galeria — Oficina Luthier</title>
  </head>
  <body>
    <Navbar />
    <main class="max-w-6xl mx-auto px-6 py-20">
      <h1 class="text-4xl font-title text-center mb-4">Galeria de Trabalhos</h1>
      <p class="text-center text-gray-400 mb-12">Conheça alguns dos instrumentos que passaram por nossas mãos. Cada peça recebe atenção e cuidado únicos.</p>

      <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="gallery-card"><img src="https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=1200&q=80&auto=format&fit=crop" alt="instrumento"/></div>
        <div class="gallery-card"><img src="https://images.unsplash.com/photo-1512436991641-6745cdb1723f?w=1200&q=80&auto=format&fit=crop" alt="instrumento"/></div>
        <div class="gallery-card"><img src="https://images.unsplash.com/photo-1526178619976-0a86b2f3c7a1?w=1200&q=80&auto=format&fit=crop" alt="instrumento"/></div>
        <div class="gallery-card"><img src="https://images.unsplash.com/photo-1542751371-adc38448a05e?w=1200&q=80&auto=format&fit=crop" alt="instrumento"/></div>
        <div class="gallery-card"><img src="https://images.unsplash.com/photo-1492684223066-81342ee5ff30?w=1200&q=80&auto=format&fit=crop" alt="instrumento"/></div>
        <div class="gallery-card"><img src="https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1200&q=80&auto=format&fit=crop" alt="instrumento"/></div>
      </section>
    </main>
  </body>
</html>
